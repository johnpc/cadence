{
  "name": "cadence",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "A Spotify-like music client for your self-hosted Jellyfin server.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "gen:icons": "node scripts/gen-app-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bddgen && playwright test",
    "crap": "node scripts/crap-check.mjs",
    "check:lines": "node scripts/check-file-lines.mjs",
    "check:features": "node scripts/check-feature-coverage.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "npm run lint && npm run format:check && npm run check:lines && npm run check:features && npm run test:coverage && npm run crap && npm run build",
    "postinstall": "patch-package",
    "prepare": "husky",
    "size": "size-limit",
    "lhci": "lhci autorun"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/libre-franklin": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@hauxir2/capacitor-chromecast": "github:hauxir/capacitor-chromecast",
    "@ionic/react": "^8.8.13",
    "@ionic/react-router": "^8.8.13",
    "@tanstack/react-query": "^5.101.2",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "ionicons": "^7.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "^0.34.6",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^17.0.8",
    "patch-package": "^8.0.1",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.9.4",
    "sharp": "^0.33.5",
    "size-limit": "^12.1.0",
    "terser": "^5.48.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^0.34.6"
  }
}
