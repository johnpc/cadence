# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/.features-gen
/playwright-report
/test-results
/blob-report
/playwright/.cache

# production
/dist

# misc
.DS_Store
# .env holds only the PUBLIC Jellyfin base URL (no secret) and MUST be committed
# so CI builds with the right VITE_JELLYFIN_URL. A global ~/.gitignore ignores
# .env, so negate it explicitly here. Real secrets live in .env.local (ignored).
!.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/.nx
/.nx/cache
/.vscode/*
!/.vscode/extensions.json
.idea

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional eslint cache
.eslintcache

# claude code (local agent state + git worktrees)
.claude
