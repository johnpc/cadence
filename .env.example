# Cadence environment template. Copy to .env.local (gitignored) for local dev/e2e.
# The committed .env holds only PUBLIC, EMPTY defaults — never put real
# addresses, ports, or tokens in a committed file.

# Base URL of your Jellyfin server (local dev / e2e). In CI this is the
# VITE_JELLYFIN_URL GitHub secret; in a self-host deploy it's the JELLYFIN_URL
# container env → runtime config.js.
VITE_JELLYFIN_URL=https://jellyfin.example.com

# e2e test-user credentials (a dedicated Jellyfin user, NOT your admin account).
TEST_USERNAME=cadence-test
TEST_PASSWORD=change-me
# Optional second user for the cross-user playlist-visibility e2e scenario.
TEST_USERNAME_2=cadence-test-2
TEST_PASSWORD_2=change-me

# OPTIONAL — faster search via a marlin-search (Meilisearch) indexer.
# Off by default: leave unset to use Jellyfin's native search. When set, it's
# only the DEFAULT URL — the user can override it (and set the token) in
# Settings. The token is NEVER a build/env var baked into client JS; it's
# entered in Settings and stored on-device.
VITE_MARLIN_URL=
